{
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "node_modules": true,
    ".husky": true,
    ".gitignore": true,
    "bun.lock": true,
    "bunfig.toml": true,
    "**/tsconfig.json": true,
    "tsdown.config.ts": true,
    ".vscode": true
  },
  "[typescript][typescriptreact][json][jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.tabSize": 2,
    "editor.rulers": [95]
  }
}
