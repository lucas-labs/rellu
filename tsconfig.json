{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "es2022",
    "moduleDetection": "force",
    "noImplicitAny": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "skipLibCheck": true,
    "allowJs": true,
    "strict": true,
    
    // Bundler mode
    "moduleResolution": "bundler",
    "noEmit": true,
  },
  "include": [
    "src/**/*.ts"
  ]
}
