{
  "name": "rellu",
  "version": "0.1.0",
  "private": true,
  "description": "Rellu - monorepo release analysis GitHub Action",
  "type": "module",
  "packageManager": "bun@1.2.2",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsdown \"src/index.ts\" --config \"tsdown.config.ts\" --out-dir \"dist\"",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "bun test",
    "test:ci": "bun run build && bun run typecheck && bun test",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^25.3.5",
    "husky": "^9.1.7",
    "tsdown": "^0.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@actions/io": "^3.0.2"
  }
}
