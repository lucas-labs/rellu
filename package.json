{
  "name": "rellu",
  "version": "1.1.0",
  "private": true,
  "description": "Rellu - monorepo release analysis GitHub Action",
  "type": "module",
  "packageManager": "bun@1.2.2",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsdown \"src/index.ts\" --config \"tsdown.config.ts\" --out-dir \"dist\" && bun run scripts/create-schemas.ts",
    "typecheck": "tsc --project tsconfig.json --noEmit && tsc --project tests/tsconfig.json --noEmit",
    "test": "bun test",
    "test:ci": "bun run build && bun run typecheck && bun test",
    "prepare": "husky",
    "format": "prettier --write \"**/*.{json,ts,js}\"",
    "act": "bun run build && act push -e .act/events/event.json",
    "act:consumer": "bun run build && act push -W .act/workflows/consumer-local.yml -e .act/events/event.json",
    "act:consumer:dry": "bun run build && act push -W .act/workflows/consumer-local.yml -e .act/events/event.json -n",
    "act:pr": "bun run build && act pull_request -e .act/events/pull_request.json",
    "act:merge": "bun run build && act pull_request -e .act/events/pull_request_merged.json",
    "act:dry": "bun run build && act push -e .act/events/event.json -n",
    "release": "bun run build && bun run scripts/release.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@inquirer/prompts": "^8.3.0",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.3.5",
    "@types/picomatch": "^4.0.2",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.0"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@actions/io": "^3.0.2",
    "jsonc-parser": "^3.3.1",
    "picomatch": "^4.0.3",
    "zod": "^4.3.6"
  }
}
